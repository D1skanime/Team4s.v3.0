{
  "realm": "team4s",
  "enabled": true,
  "displayName": "Team4s Local",
  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 86400,
  "ssoSessionMaxLifespan": 86400,
  "roles": {
    "realm": [
      {
        "name": "platform_admin",
        "description": "Global realm role for local bootstrap only. Team4s still authorizes in its own database."
      },
      {
        "name": "content_admin",
        "description": "Global realm role for local bootstrap only. Team4s still authorizes in its own database."
      },
      {
        "name": "user",
        "description": "Default local login role."
      }
    ]
  },
  "clientScopes": [
    {
      "name": "team4s-api",
      "description": "Adds the Team4s API audience to frontend-issued access tokens.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "team4s-api audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "team4s-api",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "team4s-frontend",
      "name": "Team4s Frontend",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://127.0.0.1:3002/auth"
      ],
      "webOrigins": [
        "http://127.0.0.1:3002"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "backchannel.logout.session.required": "true",
        "backchannel.logout.revoke.offline.tokens": "true"
      },
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email",
        "team4s-api"
      ]
    },
    {
      "clientId": "team4s-api",
      "name": "Team4s API",
      "enabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [],
      "webOrigins": []
    }
  ],
  "users": [
    {
      "username": "phase43-admin",
      "enabled": true,
      "email": "phase43-admin@example.local",
      "emailVerified": true,
      "firstName": "Phase",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "Team4s123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    },
    {
      "username": "phase43-member",
      "enabled": true,
      "email": "phase43-member@example.local",
      "emailVerified": true,
      "firstName": "Phase",
      "lastName": "Member",
      "credentials": [
        {
          "type": "password",
          "value": "Team4s123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    }
  ]
}
