# Copy this file to .env and fill in your own local values.
# Do not commit real secrets.

RUNTIME_PROFILE=local
AUTH_TOKEN_SECRET=
AUTH_ADMIN_ROLE_NAME=admin
AUTH_ADMIN_BOOTSTRAP_USER_IDS=
AUTH_ISSUE_DEV_MODE=false
KEYCLOAK_ENABLED=true
KEYCLOAK_ISSUER_URL=http://127.0.0.1:8081/realms/team4s
KEYCLOAK_DISCOVERY_URL=http://team4sv30-keycloak:8080/realms/team4s
KEYCLOAK_CLIENT_ID=team4s-frontend
KEYCLOAK_API_AUDIENCE=team4s-api
KEYCLOAK_ACCOUNT_URL=http://127.0.0.1:8081/realms/team4s/account
KEYCLOAK_INTERNAL_URL=http://team4sv30-keycloak:8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DB_PASSWORD=keycloak_dev_password
KEYCLOAK_PORT=8081
KEYCLOAK_POSTGRES_PORT=5434

EMBY_API_KEY=
EMBY_ALLOWED_ANIME_IDS=
EMBY_STREAM_BASE_URL=
EMBY_STREAM_PATH_TEMPLATE=/Videos/%s/stream

JELLYFIN_API_KEY=
JELLYFIN_BASE_URL=
JELLYFIN_STREAM_PATH_TEMPLATE=/Videos/%s/stream
# Optional: comma-separated Jellyfin library IDs to restrict anime search to specific libraries.
# Leave empty to search across all libraries.
# JELLYFIN_ALLOWED_LIBRARY_IDS=

# TMDB API key for asset search (cover and background).
# Get one at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Fanart.tv API key for logo and banner search.
# Get one at https://fanart.tv/get-an-api-key/
FANART_API_KEY=

NEXT_PUBLIC_API_URL=http://127.0.0.1:8092
API_INTERNAL_URL=http://backend:8092
NEXT_PUBLIC_AUTH_DISPLAY_NAME=
NEXT_PUBLIC_AUTH_TOKEN=
NEXT_PUBLIC_KEYCLOAK_ENABLED=true
NEXT_PUBLIC_KEYCLOAK_BASE_URL=http://127.0.0.1:8081
NEXT_PUBLIC_KEYCLOAK_REALM=team4s
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=team4s-frontend

# ---------------------------------------------------------------------------
# SMTP (lokal: Mailpit; Produktion: Mailjet oder anderer SMTP-Provider)
# ---------------------------------------------------------------------------
# Lokale Standardwerte zeigen auf Mailpit im Compose-Netz.
# Mailpit Web-UI ist unter http://127.0.0.1:8025 erreichbar.
# SMTP_ENABLED=true aktiviert den echten SMTP-Versand (Default in docker-compose.yml).
SMTP_ENABLED=true
SMTP_HOST=team4sv30-mailpit
SMTP_PORT=1025
SMTP_FROM=noreply@team4s.local
SMTP_FROM_NAME=Team4s
# STARTTLS lokal aus (Mailpit ohne TLS). In Produktion auf true setzen (Port 587).
SMTP_STARTTLS=false
# Basis-URL fuer absolute Links in Mails (Einladungslinks).
APP_PUBLIC_URL=http://127.0.0.1:3002

# Fuer Keycloak Account-Mails (Passwort-Reset etc.) werden dieselben
# Mailpit-Defaults aus docker-compose.yml uebernommen (KC_SMTP_*).
# Kein lokales Keycloak-SMTP-Secret noetig.

# ---------------------------------------------------------------------------
# Produktion: Mailjet
# ---------------------------------------------------------------------------
# Mailjet-Zugangsdaten kommen als SMTP-Credentials. Niemals committen.
# SMTP_ENABLED=true
# SMTP_HOST=in-v3.mailjet.com
# SMTP_PORT=587
# SMTP_FROM=noreply@team4s.de
# SMTP_FROM_NAME=Team4s
# SMTP_USER=<mailjet-api-key>
# SMTP_PASSWORD=<mailjet-secret-key>
# SMTP_STARTTLS=true
# APP_PUBLIC_URL=https://team4s.de
